{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "\"Mishu Investments\"",
  "description": "Helping investors build wealth through disciplined investing.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "pages": [
      "why-sip-works",
      "market-crash-guide",
      "start-investing",
      "contact"
    ]
  },
  "logo": {
    "light": "/images/mishu_logo_400x100.png",
    "dark": "/images/mishu_logo_400x100.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "background": {
    "image": "/images/mishu_logo_400x100.png"
  }
